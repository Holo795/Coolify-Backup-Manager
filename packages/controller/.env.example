# --- Controller configuration ---
DATABASE_URL=postgresql://cbm:cbm@localhost:5544/cbm

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Secret-at-rest master key (base64, 32 bytes). Falls back to BETTER_AUTH_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Agent enrollment shared token (leave empty for open enrollment in dev).
ENROLLMENT_TOKEN=

# First admin (seeded on startup if no user exists).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changemeplease

# Optional OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
