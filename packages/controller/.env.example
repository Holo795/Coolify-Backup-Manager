# --- Controller configuration ---
DATABASE_URL=postgresql://cbm:cbm@localhost:5544/cbm

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Secret-at-rest master key (base64, 32 bytes). Falls back to BETTER_AUTH_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Agent image referenced by the install command + GET /install.sh.
AGENT_IMAGE=ghcr.io/holo795/cbm-agent
AGENT_IMAGE_TAG=latest

# URL agents dial to reach the controller. Falls back to BETTER_AUTH_URL;
# only set if it differs (e.g. http://host.docker.internal:3000 in local dev).
AGENT_CONTROLLER_URL=

# No admin seed: the first person to register becomes the admin, then sign-up
# closes automatically. Just open the site and create your account.

# Optional OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
